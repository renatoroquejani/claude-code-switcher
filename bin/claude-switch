  chmod 600 "$PROVIDERS_FILE" 2>/dev/null || true
}

ensure_provider_catalog() {
  if [ -f "$PROVIDERS_FILE" ] && jq empty "$PROVIDERS_FILE" > /dev/null 2>&1; then
    return 0
  fi

  local bundled_file
  if bundled_file=$(get_bundled_providers_file 2>/dev/null); then
    mkdir -p "$(dirname "$PROVIDERS_FILE")"
    cp "$bundled_file" "$PROVIDERS_FILE"
    chmod 600 "$PROVIDERS_FILE" 2>/dev/null || true
    return 0
  fi

  write_default_provider_catalog
}

ensure_custom_provider_catalog() {
  ensure_json_file "$CUSTOM_PROVIDERS_FILE" '{"version":1,"providers":{}}'
}

ensure_profiles_file() {
  ensure_json_file "$PROFILES_FILE" '{"profiles":{}}'
}

provider_exists_in_catalog() {
  local provider="$1"
  jq -e --arg provider "$provider" '.providers[$provider] != null' "$PROVIDERS_FILE" > /dev/null 2>&1
}

custom_provider_exists() {
  local provider="$1"
  jq -e --arg provider "$provider" '.providers[$provider] != null' "$CUSTOM_PROVIDERS_FILE" > /dev/null 2>&1
}

provider_exists() {
  local provider="$1"

  case "$provider" in
    claude|ollama|lmstudio|z.ai|glm) return 0 ;;
  esac

  provider_exists_in_catalog "$provider" || custom_provider_exists "$provider"
}

get_provider_mapping_strategy() {
  local provider="$1"
  jq -sr --arg provider "$provider" \
    '((.[0].providers // {}) + (.[1].providers // {}))[$provider].mapping_strategy // empty' \
    "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null
}

get_provider_base_url() {
  local provider="$1"
  jq -sr --arg provider "$provider" \
    '((.[0].providers // {}) + (.[1].providers // {}))[$provider].base_url // empty' \
    "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null
}

get_provider_default_model() {
  local provider="$1"
  jq -sr --arg provider "$provider" \
    '((.[0].providers // {}) + (.[1].providers // {}))[$provider].default_model // empty' \
    "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null
}

get_provider_model_value() {
  local provider="$1"
  local tier="$2"
  jq -sr --arg provider "$provider" --arg tier "$tier" \
    '((.[0].providers // {}) + (.[1].providers // {}))[$provider].models[$tier] // empty' \
    "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null
}

resolve_provider_auth_token() {
  local provider="$1"
  local env_name

  while IFS= read -r env_name; do
    [ -z "$env_name" ] && continue
    local env_value="${!env_name:-}"
    if [ -n "$env_value" ]; then
      printf '%s\n' "$env_value"
      return 0
    fi
  done < <(jq -sr --arg provider "$provider" \
    '((.[0].providers // {}) + (.[1].providers // {}))[$provider].auth_env[]? // empty' \
    "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null)

  return 1
}

get_provider_display_name() {
  local provider="$1"
  local display_name

  display_name=$(jq -sr --arg provider "$provider" \
    '((.[0].providers // {}) + (.[1].providers // {}))[$provider].display_name // empty' \
    "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null)
  if [ -n "$display_name" ]; then
    printf '%s\n' "$display_name"
    return 0
  fi

  return 1
}

find_provider_by_base_url() {
  local base_url="$1"
  jq -sr --arg base_url "$base_url" \
    '((.[0].providers // {}) + (.[1].providers // {}))
     | to_entries[]
     | select((.value.base_url // "") == $base_url)
     | .key' \
    "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null | head -n 1
}

validate_profile_name() {
  local name="$1"

  if [ -z "$name" ]; then
    echo -e "${RED}❌ Profile name is required${NC}"
    return 1
  fi

  if [ ${#name} -gt 64 ]; then
    echo -e "${RED}❌ Profile name too long (max 64 characters)${NC}"
    return 1
  fi

  case "$name" in
    *[!a-zA-Z0-9._-]*)
      echo -e "${RED}❌ Invalid profile name: $name${NC}"
      echo "Profile names can only contain: letters, numbers, dots, underscores, and hyphens"
      return 1
      ;;
  esac

  return 0
}

profile_exists() {
  local profile_name="$1"
  jq -e --arg name "$profile_name" '.profiles[$name] != null' "$PROFILES_FILE" > /dev/null 2>&1
}

validate_provider_name() {
  local name="$1"

  if [ -z "$name" ]; then
    echo -e "${RED}❌ Provider name is required${NC}"
    return 1
  fi

  case "$name" in
    claude|ollama|lmstudio|z.ai|glm)
      echo -e "${RED}❌ Reserved provider name:${NC} $name"
      return 1
      ;;
  esac

  if [ ${#name} -gt 64 ]; then
    echo -e "${RED}❌ Provider name too long (max 64 characters)${NC}"
    return 1
  fi

  case "$name" in
    *[!a-zA-Z0-9._-]*)
      echo -e "${RED}❌ Invalid provider name: $name${NC}"
      echo "Provider names can only contain: letters, numbers, dots, underscores, and hyphens"
      return 1
      ;;
  esac

  return 0
}

validate_auth_env_name() {
  local env_name="$1"

  if [[ ! "$env_name" =~ ^[A-Z][A-Z0-9_]*$ ]]; then
    echo -e "${RED}❌ Invalid auth env name:${NC} $env_name"
    echo "Use uppercase shell env vars like MY_PROVIDER_API_KEY"
    return 1
  fi

  return 0
}

validate_account_name() {
  local name="$1"

  if [ -z "$name" ]; then
    echo -e "${RED}❌ Account name is required${NC}"
    return 1
  fi

  if [ ${#name} -gt 64 ]; then
    echo -e "${RED}❌ Account name too long (max 64 characters)${NC}"
    return 1
  fi

  case "$name" in
    *[!a-zA-Z0-9._-]*)
      echo -e "${RED}❌ Invalid account name: $name${NC}"
      echo "Account names can only contain: letters, numbers, dots, underscores, and hyphens"
      return 1
      ;;
  esac

  return 0
}

account_exists() {
  local account_name="$1"
  jq -e --arg name "$account_name" '.accounts[$name] != null' "$ACCOUNTS_FILE" > /dev/null 2>&1
}

get_account_path() {
  local account_name="$1"
  jq -r --arg name "$account_name" '.accounts[$name].path // empty' "$ACCOUNTS_FILE" 2>/dev/null
}

is_legacy_account() {
  local account_name="$1"
  jq -r --arg name "$account_name" '.accounts[$name].legacy // false' "$ACCOUNTS_FILE" 2>/dev/null
}

count_accounts() {
  jq -r '.accounts | length' "$ACCOUNTS_FILE" 2>/dev/null
}

set_active_account() {
  local account_name="$1"
  local tmp_file
  tmp_file=$(mktemp "${STATE_FILE}.tmp.XXXXXX")

  jq --arg name "$account_name" '.active_account = $name' "$STATE_FILE" > "$tmp_file"
  mv "$tmp_file" "$STATE_FILE"
  chmod 600 "$STATE_FILE" 2>/dev/null || true
}

register_account() {
  local account_name="$1"
  local account_path="$2"
  local legacy="$3"
  local tmp_file
  tmp_file=$(mktemp "${ACCOUNTS_FILE}.tmp.XXXXXX")

  jq \
    --arg name "$account_name" \
    --arg path "$account_path" \
    --argjson legacy "$legacy" \
    '.accounts[$name] = {
      path: $path,
      legacy: $legacy
    }' \
    "$ACCOUNTS_FILE" > "$tmp_file"

  mv "$tmp_file" "$ACCOUNTS_FILE"
  chmod 600 "$ACCOUNTS_FILE" 2>/dev/null || true
}

remove_account_record() {
  local account_name="$1"
  local tmp_file
  tmp_file=$(mktemp "${ACCOUNTS_FILE}.tmp.XXXXXX")

  jq --arg name "$account_name" 'del(.accounts[$name])' "$ACCOUNTS_FILE" > "$tmp_file"
  mv "$tmp_file" "$ACCOUNTS_FILE"
  chmod 600 "$ACCOUNTS_FILE" 2>/dev/null || true
}

update_account_record() {
  local account_name="$1"
  local account_path="$2"
  local legacy="$3"
  remove_account_record "$account_name"
  register_account "$account_name" "$account_path" "$legacy"
}

get_first_other_account() {
  local exclude_name="$1"
  jq -r --arg exclude "$exclude_name" '.accounts | keys | map(select(. != $exclude)) | .[0] // empty' "$ACCOUNTS_FILE" 2>/dev/null
}

get_claude_bin() {
  if [ -n "${CLAUDE_BIN:-}" ]; then
    printf '%s\n' "$CLAUDE_BIN"
    return 0
  fi

  if command -v claude > /dev/null 2>&1; then
    command -v claude
    return 0
  fi

  return 1
}

get_runtime_root_for_account() {
  local account_name="$1"

  if [ "$(is_legacy_account "$account_name")" = "true" ]; then
    printf '%s\n' "$HOME"
  else
    get_account_path "$account_name"
  fi
}

get_auth_file_for_account() {
  local runtime_root
  runtime_root=$(get_runtime_root_for_account "$1")
  printf '%s\n' "$runtime_root/.claude.json"
}

get_credentials_file_for_account() {
  local runtime_root
  runtime_root=$(get_runtime_root_for_account "$1")
  printf '%s\n' "$runtime_root/.credentials.json"
}

has_account_auth_state() {
  local account_name="$1"
  local auth_file
  local credentials_file

  auth_file=$(get_auth_file_for_account "$account_name")
  credentials_file=$(get_credentials_file_for_account "$account_name")

  if [ -f "$auth_file" ] && jq -e '.oauthAccount.emailAddress != null or .primaryApiKey != null' "$auth_file" > /dev/null 2>&1; then
    return 0
  fi

  if [ -f "$credentials_file" ] && [ -s "$credentials_file" ]; then
    return 0
  fi

  return 1
}

copy_path_if_exists() {
  local source_path="$1"
  local destination_path="$2"

  if [ ! -e "$source_path" ]; then
    return 0
  fi

  rm -rf "$destination_path"
  cp -R "$source_path" "$destination_path"
}

copy_file_if_exists() {
  local source_path="$1"
  local destination_path="$2"

  if [ ! -f "$source_path" ]; then
    return 0
  fi

  mkdir -p "$(dirname "$destination_path")"
  cp "$source_path" "$destination_path"
  chmod 600 "$destination_path" 2>/dev/null || true
}

ensure_settings_file() {
  mkdir -p "$(dirname "$SETTINGS")" "$BACKUP_DIR"
  chmod 700 "$(dirname "$SETTINGS")" "$BACKUP_DIR" 2>/dev/null || true

  if [ ! -f "$SETTINGS" ]; then
    cat > "$SETTINGS" << 'EOF'
{
  "env": {}
}
EOF
  fi

  chmod 600 "$SETTINGS" 2>/dev/null || true
}

get_project_root() {
  if [ -n "${CLAUDE_SWITCH_PROJECT_ROOT:-}" ]; then
    printf '%s\n' "$CLAUDE_SWITCH_PROJECT_ROOT"
    return 0
  fi

  local git_root
  git_root=$(git rev-parse --show-toplevel 2>/dev/null) || true
  if [ -n "$git_root" ]; then
    printf '%s\n' "$git_root"
    return 0
  fi

  local dir="$PWD"
  while [ "$dir" != "/" ] && [ "$dir" != "$HOME" ]; do
    if [ -f "$dir/.claude/settings.local.json" ]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done

  printf '%s\n' "$PWD"
}

refresh_project_paths() {
  PROJECT_ROOT=$(get_project_root)
  PROJECT_SETTINGS="$PROJECT_ROOT/.claude/settings.local.json"
  PROJECT_BACKUP_DIR="$PROJECT_ROOT/.claude/backups"
}

project_override_exists() {
  refresh_project_paths
  [ -f "$PROJECT_SETTINGS" ]
}

get_settings_path_for_scope() {
  local scope="$1"
  refresh_project_paths

  case "$scope" in
    global) printf '%s\n' "$GLOBAL_SETTINGS" ;;
    project) printf '%s\n' "$PROJECT_SETTINGS" ;;
    effective)
      if [ -f "$PROJECT_SETTINGS" ]; then
        printf '%s\n' "$PROJECT_SETTINGS"
      else
        printf '%s\n' "$GLOBAL_SETTINGS"
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

get_backup_dir_for_scope() {
  local scope="$1"
  refresh_project_paths

  case "$scope" in
    global) printf '%s\n' "$GLOBAL_BACKUP_DIR" ;;
    project) printf '%s\n' "$PROJECT_BACKUP_DIR" ;;
    effective)
      if [ -f "$PROJECT_SETTINGS" ]; then
        printf '%s\n' "$PROJECT_BACKUP_DIR"
      else
        printf '%s\n' "$GLOBAL_BACKUP_DIR"
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

get_effective_scope() {
  if project_override_exists; then
    printf '%s\n' "project"
  else
    printf '%s\n' "global"
  fi
}

use_scope_target() {
  local scope="$1"
  local target_settings
  local target_backup_dir

  target_settings=$(get_settings_path_for_scope "$scope") || return 1
  target_backup_dir=$(get_backup_dir_for_scope "$scope") || return 1

  CURRENT_SCOPE="$scope"
  SETTINGS="$target_settings"
  BACKUP_DIR="$target_backup_dir"
}

resolve_runtime_paths() {
  local account_name="$1"
  local account_path
  account_path=$(get_account_path "$account_name")

  if [ -z "$account_path" ]; then
    echo -e "${RED}❌ Account not found:${NC} $account_name"
    return 1
  fi

  CURRENT_ACCOUNT="$account_name"
  ACTIVE_ACCOUNT_DIR="$account_path"
  GLOBAL_SETTINGS="$ACTIVE_ACCOUNT_DIR/settings.json"
  GLOBAL_BACKUP_DIR="$ACTIVE_ACCOUNT_DIR/backups"
  refresh_project_paths
  use_scope_target "global" || return 1
  return 0
}

ensure_account_layout() {
  local account_name="${1:-$CURRENT_ACCOUNT}"

  resolve_runtime_paths "$account_name" || return 1
  ensure_settings_file
  return 0
}

ensure_switcher_state() {
  mkdir -p "$SWITCHER_STATE_ROOT" "$INSTANCES_DIR"
  chmod 700 "$SWITCHER_STATE_ROOT" "$INSTANCES_DIR" 2>/dev/null || true

  ensure_json_file "$ACCOUNTS_FILE" '{"accounts":{}}'
  ensure_json_file "$STATE_FILE" '{"active_account":"default"}'
  ensure_provider_catalog
  ensure_custom_provider_catalog
  ensure_profiles_file

  if ! account_exists "default"; then
    mkdir -p "$LEGACY_CLAUDE_DIR"
    chmod 700 "$LEGACY_CLAUDE_DIR" 2>/dev/null || true
    register_account "default" "$LEGACY_CLAUDE_DIR" true
  fi

  CURRENT_ACCOUNT=$(jq -r '.active_account // "default"' "$STATE_FILE" 2>/dev/null)
  if [ -z "$CURRENT_ACCOUNT" ] || ! account_exists "$CURRENT_ACCOUNT"; then
    CURRENT_ACCOUNT="default"
    set_active_account "$CURRENT_ACCOUNT"
  fi

  ensure_account_layout "$CURRENT_ACCOUNT"
}

show_account_list() {
  local active_account
  active_account=$(jq -r '.active_account // "default"' "$STATE_FILE" 2>/dev/null)

  echo ""
  echo -e "${BOLD}Accounts:${NC}"
  echo ""

  while IFS='|' read -r account_name account_path legacy; do
    [ -z "$account_name" ] && continue

    local marker=" "
    local details="$account_path"

    if [ "$account_name" = "$active_account" ]; then
      marker="*"
    fi

    if [ "$legacy" = "true" ]; then
      details="$details ${CYAN}(legacy)${NC}"
    fi

    echo -e "  ${GREEN}${marker}${NC} ${BOLD}${account_name}${NC} - $details"
  done < <(jq -r '.accounts | to_entries[] | "\(.key)|\(.value.path)|\(.value.legacy // false)"' "$ACCOUNTS_FILE" 2>/dev/null)

  echo ""
  echo "Legend: * active account"
  echo ""
}

show_current_account() {
  echo ""
  echo -e "${BOLD}Active Account:${NC}"
  echo "  Name: $CURRENT_ACCOUNT"
  echo "  Path: $ACTIVE_ACCOUNT_DIR"
  if [ "$(is_legacy_account "$CURRENT_ACCOUNT")" = "true" ]; then
    echo "  Mode: legacy"
  else
    echo "  Mode: isolated"
  fi
  echo ""
}

create_account() {
  local account_name="$1"
  local account_path

  validate_account_name "$account_name" || return 1

  if account_exists "$account_name"; then
    echo -e "${RED}❌ Account already exists:${NC} $account_name"
    return 1
  fi

  account_path="$INSTANCES_DIR/$account_name"
  mkdir -p "$account_path/backups"
  chmod 700 "$account_path" "$account_path/backups" 2>/dev/null || true

  cat > "$account_path/settings.json" << 'EOF'
{
  "env": {}
}
EOF
  chmod 600 "$account_path/settings.json" 2>/dev/null || true

  register_account "$account_name" "$account_path" false
  echo -e "${GREEN}✓${NC} Account created: ${BOLD}$account_name${NC}"
  echo "Path: $account_path"
}

use_account() {
  local account_name="$1"

  if ! account_exists "$account_name"; then
    echo -e "${RED}❌ Account not found:${NC} $account_name"
    return 1
  fi

  set_active_account "$account_name"
  ensure_account_layout "$account_name" || return 1
  echo -e "${GREEN}✓${NC} Active account: ${BOLD}$account_name${NC}"
}

rename_account() {
  local old_name="$1"
  local new_name="$2"
  local old_path
  local old_legacy

  validate_account_name "$new_name" || return 1

  if ! account_exists "$old_name"; then
    echo -e "${RED}❌ Account not found:${NC} $old_name"
    return 1
  fi

  if account_exists "$new_name"; then
    echo -e "${RED}❌ Account already exists:${NC} $new_name"
    return 1
  fi

  old_legacy=$(is_legacy_account "$old_name")
  if [ "$old_legacy" = "true" ]; then
    echo -e "${RED}❌ Legacy account cannot be renamed:${NC} $old_name"
    return 1
  fi

  old_path=$(get_account_path "$old_name")
  mv "$old_path" "$INSTANCES_DIR/$new_name"
  remove_account_record "$old_name"
  register_account "$new_name" "$INSTANCES_DIR/$new_name" false

  if [ "$(jq -r '.active_account // "default"' "$STATE_FILE" 2>/dev/null)" = "$old_name" ]; then
    set_active_account "$new_name"
    ensure_account_layout "$new_name" || return 1
  fi

  echo -e "${GREEN}✓${NC} Account renamed: ${BOLD}$old_name${NC} → ${BOLD}$new_name${NC}"
}

delete_account() {
  local account_name="$1"
  local account_path
  local legacy
  local replacement_account=""

  if ! account_exists "$account_name"; then
    echo -e "${RED}❌ Account not found:${NC} $account_name"
    return 1
  fi

  if [ "$(count_accounts)" -le 1 ]; then
    echo -e "${RED}❌ Cannot delete the last remaining account${NC}"
    return 1
  fi

  legacy=$(is_legacy_account "$account_name")
  if [ "$legacy" = "true" ]; then
    echo -e "${RED}❌ Legacy account cannot be deleted:${NC} $account_name"
    return 1
  fi

  account_path=$(get_account_path "$account_name")
  replacement_account=$(get_first_other_account "$account_name")
  rm -rf "$account_path"
  remove_account_record "$account_name"

  if [ "$(jq -r '.active_account // "default"' "$STATE_FILE" 2>/dev/null)" = "$account_name" ]; then
    set_active_account "$replacement_account"
    ensure_account_layout "$replacement_account" || return 1
  fi

  echo -e "${GREEN}✓${NC} Account deleted: ${BOLD}$account_name${NC}"
}

login_account() {
  local account_name="$1"
  local claude_bin
  local account_path

  if [ -z "$account_name" ]; then
    echo -e "${RED}❌ Account name is required${NC}"
    return 1
  fi

  if ! account_exists "$account_name"; then
    echo -e "${RED}❌ Account not found:${NC} $account_name"
    return 1
  fi

  if [ "$(is_legacy_account "$account_name")" = "true" ]; then
    echo -e "${RED}❌ Login flow is only supported for isolated accounts${NC}"
    echo "Use: claude-switch account create <name>"
    return 1
  fi

  if ! claude_bin=$(get_claude_bin); then
    echo -e "${RED}❌ Claude Code CLI not found in PATH${NC}"
    echo "Install it first: npm install -g @anthropic-ai/claude-code"
    return 1
  fi

  account_path=$(get_account_path "$account_name")
  mkdir -p "$account_path"

  echo ""
  echo -e "${BOLD}Account Login:${NC} ${GREEN}$account_name${NC}"
  echo "Runtime root: $account_path"
  echo "Launching Claude with CLAUDE_CONFIG_DIR..."
  echo ""

  CLAUDE_CONFIG_DIR="$account_path" "$claude_bin"
}

test_account_auth() {
  local account_name="${1:-$CURRENT_ACCOUNT}"
  local auth_file
  local credentials_file

  if ! account_exists "$account_name"; then
    echo -e "${RED}❌ Account not found:${NC} $account_name"
    return 1
  fi

  auth_file=$(get_auth_file_for_account "$account_name")
  credentials_file=$(get_credentials_file_for_account "$account_name")

  echo ""
  echo -e "${BOLD}Account Check:${NC} ${GREEN}$account_name${NC}"
  echo "Auth file: $auth_file"
  echo "Credentials file: $credentials_file"

  if has_account_auth_state "$account_name"; then
    if [ -f "$auth_file" ] && jq -e '.oauthAccount.emailAddress != null' "$auth_file" > /dev/null 2>&1; then
      local email
      email=$(jq -r '.oauthAccount.emailAddress' "$auth_file" 2>/dev/null)
      echo -e "${GREEN}✓${NC} Claude account detected: $email"
    elif [ -f "$auth_file" ] && jq -e '.primaryApiKey != null' "$auth_file" > /dev/null 2>&1; then
      echo -e "${GREEN}✓${NC} Claude API key state detected"
    else
      echo -e "${GREEN}✓${NC} Claude credential state detected"
    fi
    echo ""
    return 0
  fi

  echo -e "${RED}❌ No Claude authentication state detected for this account${NC}"
  if [ "$(is_legacy_account "$account_name")" = "true" ]; then
    echo "Login with your normal Claude CLI first."
  else
    echo "Run: claude-switch account login $account_name"
  fi
  echo ""
  return 1
}

import_current_account() {
  local account_name="$1"
  local account_path

  if [ -z "$account_name" ]; then
    echo -e "${RED}❌ Account name is required${NC}"
    return 1
  fi

  validate_account_name "$account_name" || return 1

  if account_exists "$account_name"; then
    echo -e "${RED}❌ Account already exists:${NC} $account_name"
    return 1
  fi

  create_account "$account_name" > /dev/null || return 1
  account_path=$(get_account_path "$account_name")

  copy_file_if_exists "$HOME/.claude.json" "$account_path/.claude.json"
  copy_file_if_exists "$HOME/.credentials.json" "$account_path/.credentials.json"
  copy_file_if_exists "$LEGACY_CLAUDE_DIR/settings.json" "$account_path/settings.json"
  copy_file_if_exists "$LEGACY_CLAUDE_DIR/policy-limits.json" "$account_path/policy-limits.json"
  copy_path_if_exists "$LEGACY_CLAUDE_DIR/backups" "$account_path/backups"
  copy_path_if_exists "$LEGACY_CLAUDE_DIR/cache" "$account_path/cache"
  copy_path_if_exists "$LEGACY_CLAUDE_DIR/plugins" "$account_path/plugins"

  chmod 700 "$account_path" 2>/dev/null || true
  [ -d "$account_path/backups" ] && chmod 700 "$account_path/backups" 2>/dev/null || true
  [ -f "$account_path/settings.json" ] && chmod 600 "$account_path/settings.json" 2>/dev/null || true
  [ -f "$account_path/.claude.json" ] && chmod 600 "$account_path/.claude.json" 2>/dev/null || true
  [ -f "$account_path/.credentials.json" ] && chmod 600 "$account_path/.credentials.json" 2>/dev/null || true

  echo -e "${GREEN}✓${NC} Imported current Claude state into: ${BOLD}$account_name${NC}"
  echo "Path: $account_path"
  echo "Next step: claude-switch account use $account_name"
}

handle_account_command() {
  local action="$1"
  shift || true

  case "$action" in
    list|ls|"") show_account_list ;;
    current) show_current_account ;;
    create) create_account "$1" ;;
    use) use_account "$1" ;;
    rename) rename_account "$1" "$2" ;;
    delete|remove|rm) delete_account "$1" ;;
    login) login_account "$1" ;;
    test) test_account_auth "$1" ;;
    import-current) import_current_account "$1" ;;
    *)
      echo -e "${RED}❌ Unknown account command:${NC} $action"
      echo "Usage: claude-switch account [list|current|create|use|rename|delete|login|test|import-current]"
      return 1
      ;;
  esac
}

get_effective_provider_spec() {
  local effective_scope
  local effective_settings
  local provider
  local mapping_strategy
  local model=""

  effective_scope=$(get_effective_scope)
  effective_settings=$(get_settings_path_for_scope "$effective_scope")
  provider=$(get_current_config_from_file "$effective_settings")

  if [ "$provider" = "unknown" ]; then
    return 1
  fi

  case "$provider" in
    openrouter|ollama)
      model=$(jq -r '.env.ANTHROPIC_MODEL // .env.ANTHROPIC_DEFAULT_HAIKU_MODEL // .env.ANTHROPIC_DEFAULT_OPUS_MODEL // empty' "$effective_settings" 2>/dev/null)
      ;;
    claude|lmstudio|anthropic-api|zai|deepseek|kimi|qwen|groq|together)
      model=""
      ;;
    *)
      mapping_strategy=$(get_provider_mapping_strategy "$provider")
      if [ "$mapping_strategy" = "single-model" ]; then
        model=$(jq -r '.env.ANTHROPIC_MODEL // .env.ANTHROPIC_DEFAULT_OPUS_MODEL // empty' "$effective_settings" 2>/dev/null)
      fi
      ;;
  esac

  if [ -n "$model" ] && [ "$model" != "null" ]; then
    printf '%s:%s\n' "$provider" "$model"
  else
    printf '%s\n' "$provider"
  fi
}

save_profile() {
  local profile_name="$1"
  local expected_provider_spec="${2:-}"
  local auto_yes="${3:-$AUTO_YES}"
  local effective_scope
  local provider_spec
  local project_root=""
  local tmp_file

  validate_profile_name "$profile_name" || return 1

  effective_scope=$(get_effective_scope)
  if ! provider_spec=$(get_effective_provider_spec); then
    echo -e "${RED}❌ Cannot save a profile for an unknown provider${NC}"
    return 1
  fi

  if [ -n "$expected_provider_spec" ] && [ "$expected_provider_spec" != "$provider_spec" ]; then
    echo -e "${RED}❌ Current provider does not match the expected profile provider${NC}"
    echo "Expected: $expected_provider_spec"
    echo "Current:  $provider_spec"
    echo "Run: claude-switch status"
    return 1
  fi

  if [ "$effective_scope" = "project" ]; then
    project_root="$PROJECT_ROOT"
  fi

  echo ""
  echo -e "${BOLD}Saving Profile:${NC}"
  echo "  Name: $profile_name"
  echo "  Account: $CURRENT_ACCOUNT"
  echo "  Scope: $effective_scope"
  echo "  Provider: $provider_spec"
  if [ -n "$project_root" ]; then
    echo "  Project Root: $project_root"
  fi

  if profile_exists "$profile_name"; then
    echo "  Existing: yes"
    if [ "$auto_yes" = "true" ]; then
      echo "  Confirmation: auto-approved via --yes"
    else
      read -p "Overwrite existing profile? [y/N] " -n 1 -r
      echo
      if [[ ! $REPLY =~ ^[SsYy]$ ]]; then
        echo "Operation cancelled"
        return 1
      fi
    fi
  else
    echo "  Existing: no"
  fi

  tmp_file=$(mktemp "${PROFILES_FILE}.tmp.XXXXXX")
  jq \
    --arg name "$profile_name" \
    --arg account "$CURRENT_ACCOUNT" \
    --arg scope "$effective_scope" \
    --arg provider_spec "$provider_spec" \
    --arg project_root "$project_root" \
    '.profiles[$name] = {
      account: $account,
      scope: $scope,
      provider_spec: $provider_spec,
      project_root: $project_root
    }' \
    "$PROFILES_FILE" > "$tmp_file"
  mv "$tmp_file" "$PROFILES_FILE"
  chmod 600 "$PROFILES_FILE" 2>/dev/null || true

  echo -e "${GREEN}✓${NC} Profile saved: ${BOLD}$profile_name${NC}"
  echo "Account: $CURRENT_ACCOUNT"
  echo "Scope: $effective_scope"
  echo "Provider: $provider_spec"
  if [ -n "$project_root" ]; then
    echo "Project Root: $project_root"
  fi
}

show_profile_list() {
  echo ""
  echo -e "${BOLD}Profiles:${NC}"
  echo ""

  if [ "$(jq -r '.profiles | length' "$PROFILES_FILE" 2>/dev/null)" = "0" ]; then
    echo "  No saved profiles"
    echo ""
    return 0
  fi

  while IFS='|' read -r profile_name account scope provider_spec project_root; do
    [ -z "$profile_name" ] && continue
    echo -e "  ${GREEN}${profile_name}${NC} - account=${account} scope=${scope} provider=${provider_spec}"
    if [ -n "$project_root" ]; then
      echo "    project=$project_root"
    fi
  done < <(jq -r '.profiles | to_entries[] | "\(.key)|\(.value.account)|\(.value.scope)|\(.value.provider_spec)|\(.value.project_root // "")"' "$PROFILES_FILE" 2>/dev/null)

  echo ""
}

delete_profile() {
  local profile_name="$1"
  local tmp_file

  if ! profile_exists "$profile_name"; then
    echo -e "${RED}❌ Profile not found:${NC} $profile_name"
    return 1
  fi

  tmp_file=$(mktemp "${PROFILES_FILE}.tmp.XXXXXX")
  jq --arg name "$profile_name" 'del(.profiles[$name])' "$PROFILES_FILE" > "$tmp_file"
  mv "$tmp_file" "$PROFILES_FILE"
  chmod 600 "$PROFILES_FILE" 2>/dev/null || true

  echo -e "${GREEN}✓${NC} Profile deleted: ${BOLD}$profile_name${NC}"
}

use_profile() {
  local profile_name="$1"
  local account_name
  local scope
  local provider_spec
  local project_root
  local previous_project_root="${CLAUDE_SWITCH_PROJECT_ROOT:-}"

  if ! profile_exists "$profile_name"; then
    echo -e "${RED}❌ Profile not found:${NC} $profile_name"
    return 1
  fi

  account_name=$(jq -r --arg name "$profile_name" '.profiles[$name].account // empty' "$PROFILES_FILE" 2>/dev/null)
  scope=$(jq -r --arg name "$profile_name" '.profiles[$name].scope // "global"' "$PROFILES_FILE" 2>/dev/null)
  provider_spec=$(jq -r --arg name "$profile_name" '.profiles[$name].provider_spec // empty' "$PROFILES_FILE" 2>/dev/null)
  project_root=$(jq -r --arg name "$profile_name" '.profiles[$name].project_root // empty' "$PROFILES_FILE" 2>/dev/null)

  if ! account_exists "$account_name"; then
    echo -e "${RED}❌ Profile account is missing:${NC} $account_name"
    echo "Use: claude-switch account create $account_name"
    return 1
  fi

  use_account "$account_name" > /dev/null || return 1

  if [ "$scope" = "project" ]; then
    if [ -z "$project_root" ]; then
      echo -e "${RED}❌ Profile is project-scoped but has no saved project root${NC}"
      return 1
    fi
    export CLAUDE_SWITCH_PROJECT_ROOT="$project_root"
    refresh_project_paths
    use_scope_target "project" || return 1
  else
    use_scope_target "global" || return 1
  fi

  run_switch_flow "$provider_spec" true "true" || {
    if [ -n "$previous_project_root" ]; then
      export CLAUDE_SWITCH_PROJECT_ROOT="$previous_project_root"
    else
      unset CLAUDE_SWITCH_PROJECT_ROOT
    fi
    refresh_project_paths
    return 1
  }

  if [ -n "$previous_project_root" ]; then
    export CLAUDE_SWITCH_PROJECT_ROOT="$previous_project_root"
  else
    unset CLAUDE_SWITCH_PROJECT_ROOT
  fi
  refresh_project_paths
  resolve_runtime_paths "$CURRENT_ACCOUNT" > /dev/null 2>&1 || true

  echo -e "${GREEN}✓${NC} Profile applied: ${BOLD}$profile_name${NC}"
}

handle_profile_command() {
  local action="$1"
  shift || true
  local auto_yes="$AUTO_YES"
  local expected_provider_spec=""

  if [ "$action" = "save" ]; then
    local profile_name="${1:-}"
    shift || true

    while [ $# -gt 0 ]; do
      case "$1" in
        -y|--yes)
          auto_yes="true"
          shift
          ;;
        --provider)
          expected_provider_spec="$2"
          shift 2
          ;;
        *)
          echo -e "${RED}❌ Unknown profile save option:${NC} $1"
          echo "Usage: claude-switch profile save <name> [--provider <provider[:model]>] [--yes]"
          return 1
          ;;
      esac
    done

    save_profile "$profile_name" "$expected_provider_spec" "$auto_yes"
    return $?
  fi

  case "$action" in
    list|ls|"") show_profile_list ;;
    use) use_profile "$1" ;;
    delete|remove|rm) delete_profile "$1" ;;
    *)
      echo -e "${RED}❌ Unknown profile command:${NC} $action"
      echo "Usage: claude-switch profile [list|save|use|delete]"
      return 1
      ;;
  esac
}

show_custom_provider_list() {
  echo ""
  echo -e "${BOLD}Custom Providers:${NC}"
  echo ""

  if [ "$(jq -r '.providers | length' "$CUSTOM_PROVIDERS_FILE" 2>/dev/null)" = "0" ]; then
    echo "  No custom providers configured"
    echo ""
    return 0
  fi

  while IFS='|' read -r provider_name display_name mapping_strategy base_url auth_env; do
    [ -z "$provider_name" ] && continue
    [ -z "$display_name" ] && display_name="$provider_name"
    echo -e "  ${GREEN}${provider_name}${NC} - ${display_name}"
    echo "    base_url=$base_url mapping=$mapping_strategy auth_env=$auth_env"
  done < <(jq -r '.providers | to_entries[] | "\(.key)|\(.value.display_name // "")|\(.value.mapping_strategy // "unknown")|\(.value.base_url // "")|\((.value.auth_env // []) | join(","))"' "$CUSTOM_PROVIDERS_FILE" 2>/dev/null)

  echo ""
}

add_custom_provider() {
  local provider_name="$1"
  shift || true
  local base_url=""
  local auth_env_csv=""
  local mapping_strategy=""
  local display_name=""
  local default_model=""
  local opus_model=""
  local sonnet_model=""
  local haiku_model=""
  local tmp_file

  validate_provider_name "$provider_name" || return 1

  if provider_exists "$provider_name"; then
    echo -e "${RED}❌ Provider already exists:${NC} $provider_name"
    return 1
  fi

  while [ $# -gt 0 ]; do
    case "$1" in
      --base-url) base_url="$2"; shift 2 ;;
      --auth-env) auth_env_csv="$2"; shift 2 ;;
      --mapping) mapping_strategy="$2"; shift 2 ;;
      --display-name) display_name="$2"; shift 2 ;;
      --model) default_model="$2"; shift 2 ;;
      --opus) opus_model="$2"; shift 2 ;;
      --sonnet) sonnet_model="$2"; shift 2 ;;
      --haiku) haiku_model="$2"; shift 2 ;;
      *)
        echo -e "${RED}❌ Unknown provider add option:${NC} $1"
        return 1
        ;;
    esac
  done

  if [ -z "$base_url" ] || [ -z "$auth_env_csv" ] || [ -z "$mapping_strategy" ]; then
    echo -e "${RED}❌ Missing required provider arguments${NC}"
    echo "Usage: claude-switch provider add <name> --base-url <url> --auth-env <ENV[,ENV2]> --mapping <provider-managed|fixed|single-model> [--display-name <name>] [--model <model>] [--opus <model> --sonnet <model> --haiku <model>]"
    return 1
  fi

  case "$mapping_strategy" in
    provider-managed) ;;
    fixed)
      [ -n "$opus_model" ] && validate_model_name "$opus_model" || { echo -e "${RED}❌ --opus is required for fixed providers${NC}"; return 1; }
      [ -n "$sonnet_model" ] && validate_model_name "$sonnet_model" || { echo -e "${RED}❌ --sonnet is required for fixed providers${NC}"; return 1; }
      [ -n "$haiku_model" ] && validate_model_name "$haiku_model" || { echo -e "${RED}❌ --haiku is required for fixed providers${NC}"; return 1; }
      ;;
    single-model)
      [ -n "$default_model" ] && validate_model_name "$default_model" || { echo -e "${RED}❌ --model is required for single-model providers${NC}"; return 1; }
      ;;
    *)
      echo -e "${RED}❌ Invalid mapping strategy:${NC} $mapping_strategy"
      return 1
      ;;
  esac

  IFS=',' read -r -a auth_env_list <<< "$auth_env_csv"
  if [ "${#auth_env_list[@]}" -eq 0 ]; then
    echo -e "${RED}❌ At least one auth env is required${NC}"
    return 1
  fi

  local auth_env_json="[]"
  local env_name
  for env_name in "${auth_env_list[@]}"; do
    validate_auth_env_name "$env_name" || return 1
    auth_env_json=$(jq -cn --argjson existing "$auth_env_json" --arg value "$env_name" '$existing + [$value]')
  done

  tmp_file=$(mktemp "${CUSTOM_PROVIDERS_FILE}.tmp.XXXXXX")
  jq \
    --arg name "$provider_name" \
    --arg base_url "$base_url" \
    --arg mapping_strategy "$mapping_strategy" \
    --arg display_name "$display_name" \
    --arg default_model "$default_model" \
    --arg opus "$opus_model" \
    --arg sonnet "$sonnet_model" \
    --arg haiku "$haiku_model" \
    --argjson auth_env "$auth_env_json" \
    '.providers[$name] = {
      base_url: $base_url,
      auth_env: $auth_env,
      mapping_strategy: $mapping_strategy
    }
    | if $display_name != "" then .providers[$name].display_name = $display_name else . end
    | if $mapping_strategy == "single-model" then .providers[$name].default_model = $default_model else . end
    | if $mapping_strategy == "fixed" then .providers[$name].models = {
        opus: $opus,
        sonnet: $sonnet,
        haiku: $haiku
      } else . end' \
    "$CUSTOM_PROVIDERS_FILE" > "$tmp_file"
  mv "$tmp_file" "$CUSTOM_PROVIDERS_FILE"
  chmod 600 "$CUSTOM_PROVIDERS_FILE" 2>/dev/null || true

  echo -e "${GREEN}✓${NC} Custom provider added: ${BOLD}$provider_name${NC}"
  echo "Base URL: $base_url"
  echo "Mapping: $mapping_strategy"
}

delete_custom_provider() {
  local provider_name="$1"
  local tmp_file

  if ! custom_provider_exists "$provider_name"; then
    echo -e "${RED}❌ Custom provider not found:${NC} $provider_name"
    return 1
  fi

  tmp_file=$(mktemp "${CUSTOM_PROVIDERS_FILE}.tmp.XXXXXX")
  jq --arg name "$provider_name" 'del(.providers[$name])' "$CUSTOM_PROVIDERS_FILE" > "$tmp_file"
  mv "$tmp_file" "$CUSTOM_PROVIDERS_FILE"
  chmod 600 "$CUSTOM_PROVIDERS_FILE" 2>/dev/null || true

  echo -e "${GREEN}✓${NC} Custom provider deleted: ${BOLD}$provider_name${NC}"
}

handle_provider_command() {
  local action="$1"
  shift || true

  case "$action" in
    list|ls|"") show_custom_provider_list ;;
    add) add_custom_provider "$@" ;;
    delete|remove|rm) delete_custom_provider "$1" ;;
    *)
      echo -e "${RED}❌ Unknown provider command:${NC} $action"
      echo "Usage: claude-switch provider [list|add|delete]"
      return 1
      ;;
  esac
}

handle_scoped_switch_command() {
  local scope="$1"
  shift || true
  local auto_yes="$AUTO_YES"
  local provider_spec=""

  while [ $# -gt 0 ]; do
    case "$1" in
      -y|--yes)
        auto_yes="true"
        shift
        ;;
      --)
        shift
        break
        ;;
      *)
        if [ -z "$provider_spec" ]; then
          provider_spec="$1"
          shift
        else
          break
        fi
        ;;
    esac
  done

  if [ -z "$provider_spec" ]; then
    echo -e "${RED}❌ Provider is required${NC}"
    echo "Usage: claude-switch $scope [--yes] <provider>"
    return 1
  fi

  use_scope_target "$scope" || return 1
  run_switch_flow "$provider_spec" true "$auto_yes"
}

reset_project_scope() {
  local backup_path

  refresh_project_paths

  if [ ! -f "$PROJECT_SETTINGS" ]; then
    echo -e "${YELLOW}No project override found${NC}"
    echo "Path: $PROJECT_SETTINGS"
    return 0
  fi

  mkdir -p "$PROJECT_BACKUP_DIR"
  chmod 700 "$PROJECT_BACKUP_DIR" 2>/dev/null || true

  backup_path="$PROJECT_BACKUP_DIR/settings.local.json.backup-$(date +%Y%m%d-%H%M%S)"
  cp "$PROJECT_SETTINGS" "$backup_path"
  chmod 600 "$backup_path" 2>/dev/null || true
  rm -f "$PROJECT_SETTINGS"

  echo -e "${GREEN}✓${NC} Removed project override"
  echo "Settings: $PROJECT_SETTINGS"
  echo "Backup: $backup_path"
}

launch_claude_for_account() {
  local account_name="${1:-$CURRENT_ACCOUNT}"
  shift || true
  local claude_bin
  local runtime_root

  if ! claude_bin=$(get_claude_bin); then
    echo -e "${RED}❌ Claude Code CLI not found in PATH${NC}"
    echo "Install it first: npm install -g @anthropic-ai/claude-code"
    return 1
  fi

  runtime_root=$(get_runtime_root_for_account "$account_name")

  if [ "$(is_legacy_account "$account_name")" = "true" ]; then
    CLAUDE_SWITCHER_ACCOUNT="$account_name" "$claude_bin" "$@"
  else
    CLAUDE_CONFIG_DIR="$runtime_root" CLAUDE_SWITCHER_ACCOUNT="$account_name" "$claude_bin" "$@"
  fi
}

show_launch_hint() {
  echo ""
  if [ "$(is_legacy_account "$CURRENT_ACCOUNT")" = "true" ]; then
    echo -e "${GREEN}✓${NC} Start with: ${BOLD}claude${NC}"
  else
    echo -e "${GREEN}✓${NC} Start with: ${BOLD}claude-switch exec --${NC}"
  fi
}

show_applied_model_mapping() {
  local provider="$1"
  local mapping_strategy

  echo ""
  echo -e "${BOLD}Model Mapping:${NC}"

  mapping_strategy=$(get_provider_mapping_strategy "$provider")

  case "$provider:$mapping_strategy" in
    zai:provider-managed|*:provider-managed)
      echo -e "  Opus   → ${GREEN}<provider-managed>${NC}"
      echo -e "  Sonnet → ${GREEN}<provider-managed>${NC}"
      echo -e "  Haiku  → ${GREEN}<provider-managed>${NC}"
      if [ "$provider" = "zai" ]; then
        echo -e "  ${CYAN}Z.AI handles tier-to-model mapping internally${NC}"
      else
        echo -e "  ${CYAN}This provider handles tier-to-model mapping internally${NC}"
      fi
      ;;
    *)
      echo -e "  Opus   → ${GREEN}$(jq -r '.env.ANTHROPIC_DEFAULT_OPUS_MODEL // "default"' "$SETTINGS" 2>/dev/null)${NC}"
      echo -e "  Sonnet → ${GREEN}$(jq -r '.env.ANTHROPIC_DEFAULT_SONNET_MODEL // "default"' "$SETTINGS" 2>/dev/null)${NC}"
      echo -e "  Haiku  → ${GREEN}$(jq -r '.env.ANTHROPIC_DEFAULT_HAIKU_MODEL // "default"' "$SETTINGS" 2>/dev/null)${NC}"
      ;;
  esac
}

show_launch_summary() {
  local summary_scope
  local summary_settings
  local current_provider
  local base_url

  summary_scope=$(get_effective_scope)
  summary_settings=$(get_settings_path_for_scope "$summary_scope")
  current_provider=$(get_current_config_from_file "$summary_settings")
  base_url=$(jq -r '.env.ANTHROPIC_BASE_URL // empty' "$summary_settings" 2>/dev/null)

  echo ""
  echo -e "${BOLD}Launch Summary:${NC}"
  echo "  Account: $CURRENT_ACCOUNT"
  if [ "$(is_legacy_account "$CURRENT_ACCOUNT")" = "true" ]; then
    echo "  Mode: legacy"
  else
    echo "  Mode: isolated"
  fi
  echo "  Scope: $summary_scope"
  echo "  Provider: $(get_friendly_name "$current_provider")"
  echo "  Settings: $summary_settings"
  if [ -n "$base_url" ]; then
    echo "  Base URL: $base_url"
  fi
  if [ "$summary_scope" = "project" ]; then
    echo "  Project Root: $PROJECT_ROOT"
  fi
  if [ "$(is_legacy_account "$CURRENT_ACCOUNT")" != "true" ]; then
    echo "  CLAUDE_CONFIG_DIR: $ACTIVE_ACCOUNT_DIR"
  fi
  echo ""
}

