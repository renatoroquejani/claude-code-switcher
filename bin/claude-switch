#!/bin/bash
VERSION="2.3.0"
REPO_URL="https://github.com/renatoroquejani/claude-code-switcher"
RAW_BASE_URL="${CLAUDE_SWITCHER_UPDATE_BASE_URL:-https://raw.githubusercontent.com/renatoroquejani/claude-code-switcher/main}"
LEGACY_CLAUDE_DIR="${CLAUDE_HOME:-${LEGACY_CLAUDE_DIR:-$HOME/.claude}}"
SWITCHER_STATE_ROOT="${CLAUDE_SWITCHER_HOME:-${SWITCHER_STATE_ROOT:-$HOME/.claude-switcher}}"
INSTANCES_DIR="${SWITCHER_INSTANCES_DIR:-$SWITCHER_STATE_ROOT/instances}"
ACCOUNTS_FILE="${ACCOUNTS_FILE:-$SWITCHER_STATE_ROOT/accounts.json}"
STATE_FILE="${STATE_FILE:-$SWITCHER_STATE_ROOT/state.json}"
PROVIDERS_FILE="${CLAUDE_SWITCHER_PROVIDERS_FILE:-$SWITCHER_STATE_ROOT/providers.json}"
CUSTOM_PROVIDERS_FILE="${CLAUDE_SWITCHER_CUSTOM_PROVIDERS_FILE:-$SWITCHER_STATE_ROOT/custom-providers.json}"
PROFILES_FILE="${CLAUDE_SWITCHER_PROFILES_FILE:-$SWITCHER_STATE_ROOT/profiles.json}"
SETTINGS=""
BACKUP_DIR=""
ACTIVE_ACCOUNT_DIR=""
CURRENT_ACCOUNT=""
AUTO_YES="false"
GLOBAL_SETTINGS=""
GLOBAL_BACKUP_DIR=""
PROJECT_ROOT=""
PROJECT_SETTINGS=""
PROJECT_BACKUP_DIR=""
CURRENT_SCOPE="global"

# Colors
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
RED=$'\033[0;31m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ACCOUNT STATE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

write_json_file() {
  local file="$1"
  local content="$2"

  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$content" > "$file"
  chmod 600 "$file" 2>/dev/null || true
}

ensure_json_file() {
  local file="$1"
  local default_content="$2"

  if [ ! -f "$file" ]; then
    write_json_file "$file" "$default_content"
  fi
}

get_bundled_providers_file() {
  local bundled_file
  bundled_file="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../config/providers.json"

  if [ -f "$bundled_file" ]; then
    printf '%s\n' "$bundled_file"
    return 0
  fi

  return 1
}

write_default_provider_catalog() {
  mkdir -p "$(dirname "$PROVIDERS_FILE")"
  cat > "$PROVIDERS_FILE" << 'EOF'
{
  "version": 1,
  "providers": {
    "anthropic-api": {
      "base_url": "https://api.anthropic.com",
      "auth_env": [
        "ANTHROPIC_API_KEY"
      ],
      "mapping_strategy": "fixed",
      "models": {
        "opus": "claude-opus-4-6",
        "sonnet": "claude-sonnet-4-5-20250929",
        "haiku": "claude-haiku-4-20250920"
      }
    },
    "zai": {
      "base_url": "https://api.z.ai/api/anthropic",
      "auth_env": [
        "ZAI_API_KEY",
