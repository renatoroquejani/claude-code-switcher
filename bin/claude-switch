list_providers() {
  echo ""
  echo -e "${BOLD}Available Providers:${NC}"
  echo ""
  echo -e "${YELLOW}CLOUD (paid):${NC}"
  echo "  claude        - Anthropic Claude OAuth (Opus/Sonnet/Haiku)"
  echo "  anthropic-api - Anthropic Claude API (requires key)"
  echo "  zai           - Z.AI GLM (provider-managed)"
  echo "  deepseek      - DeepSeek Chat/Coder"
  echo "  kimi          - Kimi (Moonshot AI)"
  echo "  qwen          - Qwen Coder (32B/14B/7B)"
  echo "  groq          - Groq (Llama 3.3/Mixtral)"
  echo "  together      - Together AI (70B/8x7B/7B)"
  echo "  openrouter    - OpenRouter (100+ models)"
  echo ""
  echo -e "${YELLOW}LOCAL (free):${NC}"
  echo "  ollama        - Ollama (local GGUF models)"
  echo "  lmstudio      - LM Studio (GUI)"
  echo ""

  if [ "$(jq -r '.providers | length' "$CUSTOM_PROVIDERS_FILE" 2>/dev/null)" != "0" ]; then
    echo -e "${YELLOW}CUSTOM:${NC}"
    while IFS='|' read -r provider_name display_name mapping_strategy; do
      [ -z "$provider_name" ] && continue
      [ -z "$display_name" ] && display_name="$provider_name"
      echo "  $provider_name - $display_name ($mapping_strategy)"
    done < <(jq -r '.providers | to_entries[] | "\(.key)|\(.value.display_name // "")|\(.value.mapping_strategy // "unknown")"' "$CUSTOM_PROVIDERS_FILE" 2>/dev/null)
    echo ""
  fi

  echo -e "${YELLOW}Installed Ollama Models:${NC}"
  if command -v ollama &> /dev/null; then
    ollama list 2>/dev/null || echo "  No models installed"
  else
    echo "  Ollama not installed"
  fi
  echo ""
}

show_model_mapping() {
  local provider="$1"
  local mapping_strategy
  local model

  if [ -z "$provider" ]; then
    echo -e "${RED}Usage: claude-switch models <provider>${NC}"
    echo ""
    echo "Example: claude-switch models zai"
    return 1
  fi

  echo ""
  echo -e "${BOLD}Model Mapping for: ${GREEN}$provider${NC}${BOLD}${NC}"
  echo ""
  echo -e "${YELLOW}Claude Code Tier${NC}  →  ${YELLOW}Provider Model${NC}"
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

  case "$provider" in
    claude)
      echo -e "  Opus    →  claude-opus-4-6"
      echo -e "  Sonnet  →  claude-sonnet-4-5-20250929"
      echo -e "  Haiku   →  claude-haiku-4-20250920"
      ;;
    ollama)
      local installed=$(ollama list 2>/dev/null | tail -n +2 | awk '{print $1}')
      local opus="qwen3-coder:32b" sonnet="qwen3-coder:14b" haiku="qwen3-coder:7b"

      echo "$installed" | grep -q "^${opus}" || opus="$sonnet"
      echo "$installed" | grep -q "^${opus}" || opus="$haiku"
      echo "$installed" | grep -q "^${sonnet}" || sonnet="$opus"
      echo "$installed" | grep -q "^${haiku}" || haiku="$sonnet"
      [ -z "$opus" ] && opus=$(echo "$installed" | head -1)

      echo -e "  Opus    →  ${opus:-<not set>}"
      echo -e "  Sonnet  →  ${sonnet:-<not set>}"
      echo -e "  Haiku   →  ${haiku:-<not set>} ${CYAN}(default)${NC}"
      echo ""
      echo -e "${CYAN}(Tiered models: 32b/14b/7b - 7b is default for local use)${NC}"
      ;;
    lmstudio)
      echo -e "  Opus    →  <loaded in LM Studio>"
      echo -e "  Sonnet  →  <loaded in LM Studio>"
      echo -e "  Haiku   →  <loaded in LM Studio>"
      echo ""
      echo -e "${CYAN}(Uses whatever model is loaded in LM Studio)${NC}"
      ;;
    *)
      case "$provider" in
        z.ai|glm) provider="zai" ;;
      esac

      if provider_exists "$provider"; then
        mapping_strategy=$(get_provider_mapping_strategy "$provider")
        case "$mapping_strategy" in
          provider-managed)
            echo -e "  Opus    →  <provider-managed>"
            echo -e "  Sonnet  →  <provider-managed>"
            echo -e "  Haiku   →  <provider-managed>"
            echo ""
            echo -e "${CYAN}(Tier mapping is handled by $(get_friendly_name "$provider"))${NC}"
            ;;
          fixed)
            echo -e "  Opus    →  $(get_provider_model_value "$provider" "opus")"
            echo -e "  Sonnet  →  $(get_provider_model_value "$provider" "sonnet")"
            echo -e "  Haiku   →  $(get_provider_model_value "$provider" "haiku")"
            ;;
          single-model)
            if [ "$provider" = "openrouter" ]; then
              model="${OPENROUTER_DEFAULT_MODEL:-$(get_provider_default_model "$provider")}"
            else
              model="$(get_provider_default_model "$provider")"
            fi
            echo -e "  Opus    →  $model"
            echo -e "  Sonnet  →  $model"
            echo -e "  Haiku   →  $model"
            echo ""
            echo -e "${CYAN}(All tiers use the same provider model)${NC}"
            ;;
          *)
            echo -e "${RED}Unknown provider mapping strategy:${NC} $mapping_strategy"
            return 1
            ;;
        esac
      else
        echo -e "${RED}Unknown provider: $provider${NC}"
        echo "Run: claude-switch list"
        return 1
      fi
      ;;
  esac
  echo ""
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CURRENT CONFIG DETECTION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

get_current_config_from_file() {
  local settings_file="$1"
  local base_url="oauth"
  local matched_provider=""

  [ -f "$settings_file" ] && base_url=$(jq -r '.env.ANTHROPIC_BASE_URL // "oauth"' "$settings_file" 2>/dev/null)

  case "$base_url" in
    "oauth"|"null") echo "claude"; return 0 ;;
    *"localhost:11434"*|*"127.0.0.1:11434"*) echo "ollama"; return 0 ;;
    *"localhost:1234"*|*"127.0.0.1:1234"*) echo "lmstudio"; return 0 ;;
  esac

  matched_provider=$(find_provider_by_base_url "$base_url")
  if [ -n "$matched_provider" ]; then
    echo "$matched_provider"
    return 0
  fi

  case "$base_url" in
    *"api.anthropic.com"*) echo "anthropic-api" ;;
    *"z.ai"*) echo "zai" ;;
    *"deepseek"*) echo "deepseek" ;;
    *"moonshot"*) echo "kimi" ;;
    *"siliconflow"*) echo "qwen" ;;
    *"groq"*) echo "groq" ;;
    *"together"*) echo "together" ;;
    *"openrouter"*) echo "openrouter" ;;
    *) echo "unknown" ;;
  esac
}

get_current_config() {
  get_current_config_from_file "$SETTINGS"
}

get_current_config_for_scope() {
  case "$CURRENT_SCOPE" in
    project)
      get_current_config_from_file "$(get_settings_path_for_scope "effective")"
      ;;
    *)
      get_current_config
      ;;
  esac
}

get_friendly_name() {
  local custom_name=""

  if custom_name=$(get_provider_display_name "$1" 2>/dev/null); then
    if [ -n "$custom_name" ]; then
      printf '%s\n' "$custom_name"
      return 0
    fi
  fi

  case "$1" in
    claude) echo "Claude (Anthropic OAuth)" ;;
    anthropic-api) echo "Claude (Anthropic API)" ;;
    zai|z.ai|glm) echo "Z.AI (GLM)" ;;
    deepseek) echo "DeepSeek" ;;
    kimi) echo "Kimi (Moonshot)" ;;
    qwen) echo "Qwen Coder" ;;
    groq) echo "Groq" ;;
    together) echo "Together AI" ;;
    openrouter) echo "OpenRouter" ;;
    ollama) echo "Ollama (Local)" ;;
    lmstudio) echo "LM Studio (Local)" ;;
    *) echo "Unknown" ;;
  esac
}

show_status() {
  local effective_scope
  local effective_settings
  local current
  local current_name
  local base_url
  local opus_model
  local sonnet_model
  local haiku_model

  effective_scope=$(get_effective_scope)
  effective_settings=$(get_settings_path_for_scope "$effective_scope")
  current=$(get_current_config_from_file "$effective_settings")
  current_name=$(get_friendly_name "$current")

  echo ""
  echo -e "${BOLD}Current Status:${NC}"
  echo -e "  Account: ${GREEN}$CURRENT_ACCOUNT${NC}"
  echo "  Scope: $effective_scope"
  echo "  Settings: $effective_settings"
  echo -e "  Provider: ${GREEN}$current_name${NC}"
  if [ "$effective_scope" = "project" ]; then
    echo "  Project Root: $PROJECT_ROOT"
  fi

  base_url=$(jq -r '.env.ANTHROPIC_BASE_URL // "oauth"' "$effective_settings" 2>/dev/null)
  if [ "$base_url" != "oauth" ] && [ "$base_url" != "null" ]; then
    echo "  Base URL: $base_url"
  fi

  opus_model=$(jq -r '.env.ANTHROPIC_DEFAULT_OPUS_MODEL // "default"' "$effective_settings" 2>/dev/null)
  if [ "$opus_model" != "default" ] && [ "$opus_model" != "null" ]; then
    echo "  Opus: $opus_model"
  fi

  sonnet_model=$(jq -r '.env.ANTHROPIC_DEFAULT_SONNET_MODEL // "default"' "$effective_settings" 2>/dev/null)
  if [ "$sonnet_model" != "default" ] && [ "$sonnet_model" != "null" ]; then
    echo "  Sonnet: $sonnet_model"
  fi

  haiku_model=$(jq -r '.env.ANTHROPIC_DEFAULT_HAIKU_MODEL // "default"' "$effective_settings" 2>/dev/null)
  if [ "$haiku_model" != "default" ] && [ "$haiku_model" != "null" ]; then
    echo "  Haiku: $haiku_model"
  fi
  echo ""
}

show_where() {
  local effective_scope
  local effective_settings

  effective_scope=$(get_effective_scope)
  effective_settings=$(get_settings_path_for_scope "$effective_scope")

  echo ""
  echo -e "${BOLD}Resolution:${NC}"
  echo "  Account: $CURRENT_ACCOUNT"
  if [ "$(is_legacy_account "$CURRENT_ACCOUNT")" = "true" ]; then
    echo "  Mode: legacy"
  else
    echo "  Mode: isolated"
  fi
  echo "  Project Root: $PROJECT_ROOT"
  echo "  Global Settings: $GLOBAL_SETTINGS"
  echo "  Project Settings: $PROJECT_SETTINGS"
  if [ -f "$PROJECT_SETTINGS" ]; then
    echo "  Project Override: yes"
  else
    echo "  Project Override: no"
  fi
  echo "  Effective Scope: $effective_scope"
  echo "  Effective Settings: $effective_settings"
  echo ""
}

doctor_init_report() {
  DOCTOR_REPORT_FILE=$(mktemp)
  printf '[]\n' > "$DOCTOR_REPORT_FILE"
  DOCTOR_HAS_FAILURES="false"
  DOCTOR_HAS_WARNINGS="false"
}

doctor_cleanup_report() {
  [ -n "${DOCTOR_REPORT_FILE:-}" ] && rm -f "$DOCTOR_REPORT_FILE"
  DOCTOR_REPORT_FILE=""
}

doctor_add_check() {
  local check_id="$1"
  local status="$2"
  local summary="$3"
  local details="${4:-}"
  local remedy="${5:-}"
  local icon="✓"
  local color="$GREEN"
  local ok="true"

  case "$status" in
    pass)
      ;;
    warn)
      icon="!"
      color="$YELLOW"
      ok="false"
      DOCTOR_HAS_WARNINGS="true"
      ;;
    fail)
      icon="✗"
      color="$RED"
      ok="false"
      DOCTOR_HAS_FAILURES="true"
      ;;
    *)
      status="warn"
      icon="!"
      color="$YELLOW"
      ok="false"
      DOCTOR_HAS_WARNINGS="true"
      ;;
  esac

  if [ "${DOCTOR_JSON_MODE:-false}" != "true" ]; then
    echo -e "  ${color}${icon}${NC} ${BOLD}${check_id}${NC} - $summary"
    [ -n "$details" ] && echo "    $details"
    [ -n "$remedy" ] && echo "    Fix: $remedy"
  fi

  local tmp_file
  tmp_file=$(mktemp "${DOCTOR_REPORT_FILE}.tmp.XXXXXX")
  jq \
    --arg id "$check_id" \
    --arg status "$status" \
    --arg summary "$summary" \
    --arg details "$details" \
    --arg remedy "$remedy" \
    --argjson ok "$ok" \
    '. += [{
      id: $id,
      status: $status,
      ok: $ok,
      summary: $summary,
      details: $details,
      remedy: $remedy
    }]' \
    "$DOCTOR_REPORT_FILE" > "$tmp_file"
  mv "$tmp_file" "$DOCTOR_REPORT_FILE"
}

doctor_check_json_file() {
  local check_id="$1"
  local file_path="$2"
  local description="$3"
  local missing_status="${4:-fail}"

  if [ ! -f "$file_path" ]; then
    doctor_add_check "$check_id" "$missing_status" "$description not found" "Path: $file_path"
    return 1
  fi

  if jq empty "$file_path" > /dev/null 2>&1; then
    doctor_add_check "$check_id" "pass" "$description is valid JSON" "Path: $file_path"
    return 0
  fi

  doctor_add_check "$check_id" "fail" "$description is invalid JSON" "Path: $file_path" "Repair or recreate the JSON file"
  return 1
}

doctor_check_local_provider() {
  local provider="$1"

  case "$provider" in
    ollama)
      if ! command -v ollama > /dev/null 2>&1; then
        doctor_add_check "local_provider" "fail" "Ollama is configured but not installed" "" "Install Ollama and start the local server"
        return
      fi
      if pgrep -x ollama > /dev/null 2>&1; then
        doctor_add_check "local_provider" "pass" "Ollama is installed and running"
      else
        doctor_add_check "local_provider" "fail" "Ollama is configured but not running" "" "Run: ollama serve"
      fi
      ;;
    lmstudio)
      if curl -s http://localhost:1234/v1/models > /dev/null 2>&1; then
        doctor_add_check "local_provider" "pass" "LM Studio local server is reachable"
      else
        doctor_add_check "local_provider" "fail" "LM Studio is configured but the local server is unreachable" "" "Open LM Studio, load a model, and start the local server"
      fi
      ;;
    *)
      doctor_add_check "local_provider" "pass" "Current provider does not require a local runtime" "Provider: $(get_friendly_name "$provider")"
      ;;
  esac
}

doctor_emit_json() {
  local overall_status="healthy"
  local ok="true"

  if [ "$DOCTOR_HAS_FAILURES" = "true" ]; then
    overall_status="broken"
    ok="false"
  elif [ "$DOCTOR_HAS_WARNINGS" = "true" ]; then
    overall_status="degraded"
    ok="false"
  fi

  jq -n \
    --arg status "$overall_status" \
    --arg account "$CURRENT_ACCOUNT" \
    --arg scope "$(get_effective_scope)" \
    --arg provider "$(get_current_config_from_file "$(get_settings_path_for_scope "$(get_effective_scope)")")" \
    --arg provider_name "$(get_friendly_name "$(get_current_config_from_file "$(get_settings_path_for_scope "$(get_effective_scope)")")")" \
    --arg settings "$(get_settings_path_for_scope "$(get_effective_scope)")" \
    --arg project_root "$PROJECT_ROOT" \
    --arg global_settings "$GLOBAL_SETTINGS" \
    --arg project_settings "$PROJECT_SETTINGS" \
    --argjson ok "$ok" \
    --slurpfile checks "$DOCTOR_REPORT_FILE" \
    '{
      ok: $ok,
      status: $status,
      account: $account,
      scope: $scope,
      provider: {
        id: $provider,
        name: $provider_name
      },
      settings: {
        effective: $settings,
        global: $global_settings,
        project: $project_settings
      },
      project_root: $project_root,
      checks: $checks[0]
    }'
}

run_doctor_missing_jq() {
  local json_mode="false"
  [ "${1:-}" = "--json" ] && json_mode="true"

  if [ "$json_mode" = "true" ]; then
    cat << 'EOF'
{"ok":false,"status":"broken","checks":[{"id":"jq","status":"fail","ok":false,"summary":"jq is not installed","details":"","remedy":"Install jq and re-run claude-switch doctor"}]}
EOF
  else
    echo ""
    echo -e "${BOLD}Doctor:${NC}"
    echo "  ${RED}✗${NC} jq - jq is not installed"
    echo "    Fix: Install jq and re-run claude-switch doctor"
    echo ""
  fi
  return 1
}

run_doctor() {
  local effective_scope
  local effective_settings
  local provider
  local claude_bin=""

  DOCTOR_JSON_MODE="false"
  if [ "${1:-}" = "--json" ]; then
    DOCTOR_JSON_MODE="true"
    shift
  fi

  doctor_init_report
  trap doctor_cleanup_report RETURN

  effective_scope=$(get_effective_scope)
  effective_settings=$(get_settings_path_for_scope "$effective_scope")
  provider=$(get_current_config_from_file "$effective_settings")

  if [ "$DOCTOR_JSON_MODE" != "true" ]; then
    echo ""
    echo -e "${BOLD}Doctor:${NC}"
    echo "  Account: $CURRENT_ACCOUNT"
    echo "  Scope: $effective_scope"
    echo "  Provider: $(get_friendly_name "$provider")"
    echo "  Settings: $effective_settings"
    echo ""
  fi

  doctor_add_check "jq" "pass" "jq is installed" "Path: $(command -v jq)"

  if claude_bin=$(get_claude_bin 2>/dev/null); then
    doctor_add_check "claude" "pass" "Claude Code CLI is installed" "Path: $claude_bin"
  else
    doctor_add_check "claude" "fail" "Claude Code CLI is not available in PATH" "" "Install with: npm install -g @anthropic-ai/claude-code"
  fi

  doctor_check_json_file "accounts" "$ACCOUNTS_FILE" "Account registry"
  doctor_check_json_file "state" "$STATE_FILE" "State file"
  doctor_check_json_file "provider_catalog" "$PROVIDERS_FILE" "Provider catalog"
  doctor_check_json_file "custom_providers" "$CUSTOM_PROVIDERS_FILE" "Custom provider catalog"
  doctor_check_json_file "profiles" "$PROFILES_FILE" "Profile registry"

  if ! jq -e --arg name "$CURRENT_ACCOUNT" '.accounts[$name] != null' "$ACCOUNTS_FILE" > /dev/null 2>&1; then
    doctor_add_check "active_account" "fail" "Active account is missing from the registry" "Account: $CURRENT_ACCOUNT" "Use: claude-switch account use <name>"
  else
    doctor_add_check "active_account" "pass" "Active account is registered" "Account: $CURRENT_ACCOUNT"
  fi

  doctor_check_json_file "global_settings" "$GLOBAL_SETTINGS" "Global settings" || true

  if [ -f "$PROJECT_SETTINGS" ]; then
    doctor_check_json_file "project_settings" "$PROJECT_SETTINGS" "Project override" || true
  else
    doctor_add_check "project_settings" "pass" "No project override present" "Path: $PROJECT_SETTINGS"
  fi

  doctor_check_json_file "effective_settings" "$effective_settings" "Effective settings" || true

  if has_account_auth_state "$CURRENT_ACCOUNT"; then
    doctor_add_check "auth" "pass" "Active account has Claude authentication state"
  else
    if [ "$provider" = "claude" ]; then
      doctor_add_check "auth" "fail" "Claude OAuth is configured but no account auth state was found" "" "Run: claude-switch account login $CURRENT_ACCOUNT"
    else
      doctor_add_check "auth" "warn" "No Claude auth state found for the active account" "Current provider uses $(get_friendly_name "$provider"), so this may be expected"
    fi
  fi

  doctor_check_local_provider "$provider"

  if [ "$DOCTOR_JSON_MODE" = "true" ]; then
    doctor_emit_json
  else
    local overall_status="healthy"
    if [ "$DOCTOR_HAS_FAILURES" = "true" ]; then
      overall_status="broken"
    elif [ "$DOCTOR_HAS_WARNINGS" = "true" ]; then
      overall_status="degraded"
    fi

    echo ""
    echo -e "${BOLD}Summary:${NC} $overall_status"
    echo ""
  fi

  if [ "$DOCTOR_HAS_FAILURES" = "true" ]; then
    return 1
  fi

  return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# VALIDATIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

validate_key() {
  local key_name="$1"
  local key_value="${!key_name}"

  if [ -z "$key_value" ]; then
    echo -e "${RED}❌ $key_name not configured${NC}"
    echo "Configure it in: ~/.claude/api-keys.env"
    echo "Or run: claude-switch keys"
    return 1
  fi
  return 0
}

check_ollama() {
  if ! command -v ollama &> /dev/null; then
    echo -e "${RED}❌ Ollama not installed${NC}"
    echo "Install with: curl -fsSL https://ollama.com/install.sh | sh"
    return 1
  fi

  if ! pgrep -x ollama > /dev/null; then
    echo -e "${YELLOW}⚠️  Ollama is not running${NC}"
    echo "Start with: ollama serve"
    read -p "Start now? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[SsYy]$ ]]; then
      nohup ollama serve > /dev/null 2>&1 &
      sleep 2
      echo -e "${GREEN}✓${NC} Ollama started"
    else
      return 1
    fi
  fi
  return 0
}

check_lmstudio() {
  if ! curl -s http://localhost:1234/v1/models > /dev/null 2>&1; then
    echo -e "${RED}❌ LM Studio is not running${NC}"
    echo "Open LM Studio and:"
    echo "1. Load a model"
    echo "2. Go to 'Local Server'"
    echo "3. Click 'Start Server'"
    return 1
  fi
  return 0
}

validate_model_name() {
  local model="$1"

  if [ -z "$model" ]; then
    return 0
  fi

  if [ ${#model} -gt 255 ]; then
    echo -e "${RED}❌ Model name too long (max 255 characters)${NC}"
    return 1
  fi

  case "$model" in
    *[!a-zA-Z0-9_\-/:.]*)
      echo -e "${RED}❌ Invalid model name: $model${NC}"
      echo "Model names can only contain: letters, numbers, hyphens, underscores, slashes, colons, and dots"
      return 1
      ;;
  esac

  if [[ "$model" =~ \.\. ]]; then
    echo -e "${RED}❌ Path traversal not allowed${NC}"
    return 1
  fi

  return 0
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APPLY CONFIGURATIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

clear_all_models() {
  local tmp_settings
  tmp_settings=$(mktemp "${SETTINGS}.tmp.XXXXXX")
  if [ "$CURRENT_SCOPE" = "project" ]; then
    jq '.env.ANTHROPIC_MODEL = null |
        .env.ANTHROPIC_DEFAULT_OPUS_MODEL = null |
        .env.ANTHROPIC_DEFAULT_SONNET_MODEL = null |
        .env.ANTHROPIC_DEFAULT_HAIKU_MODEL = null' \
       "$SETTINGS" > "$tmp_settings"
  else
    jq 'del(.env.ANTHROPIC_MODEL,
            .env.ANTHROPIC_DEFAULT_OPUS_MODEL,
            .env.ANTHROPIC_DEFAULT_SONNET_MODEL,
            .env.ANTHROPIC_DEFAULT_HAIKU_MODEL)' \
       "$SETTINGS" > "$tmp_settings"
  fi
  mv "$tmp_settings" "$SETTINGS"
}

clear_provider_connection() {
  local tmp_settings
  tmp_settings=$(mktemp "${SETTINGS}.tmp.XXXXXX")

  if [ "$CURRENT_SCOPE" = "project" ]; then
    jq '.env.ANTHROPIC_AUTH_TOKEN = null |
        .env.ANTHROPIC_BASE_URL = null' \
       "$SETTINGS" > "$tmp_settings"
  else
    jq 'del(.env.ANTHROPIC_AUTH_TOKEN, .env.ANTHROPIC_BASE_URL)' \
       "$SETTINGS" > "$tmp_settings"
  fi

  mv "$tmp_settings" "$SETTINGS"
}

provider_config_needs_refresh() {
  local provider="$1"

  case "$provider" in
    zai)
      if jq -e '.env.ANTHROPIC_DEFAULT_OPUS_MODEL != null or .env.ANTHROPIC_DEFAULT_SONNET_MODEL != null or .env.ANTHROPIC_DEFAULT_HAIKU_MODEL != null' "$SETTINGS" > /dev/null 2>&1; then
        return 0
      fi
      return 1
      ;;
    *)
      return 1
      ;;
  esac
}

apply_catalog_provider() {
  local provider="$1"
  local override_model="$2"
  local token
  local base_url
  local mapping_strategy
  local tmp_settings

  if ! provider_exists "$provider"; then
    return 1
  fi

  base_url=$(get_provider_base_url "$provider")
  mapping_strategy=$(get_provider_mapping_strategy "$provider")

  if ! token=$(resolve_provider_auth_token "$provider"); then
    local first_env
    first_env=$(jq -sr --arg provider "$provider" \
      '((.[0].providers // {}) + (.[1].providers // {}))[$provider].auth_env[0] // "API_KEY"' \
      "$PROVIDERS_FILE" "$CUSTOM_PROVIDERS_FILE" 2>/dev/null)
    echo -e "${RED}❌ ${first_env} not configured${NC}"
    echo "Configure it in: ~/.claude/api-keys.env"
    echo "Or run: claude-switch keys"
    return 1
  fi

  clear_all_models
  tmp_settings=$(mktemp "${SETTINGS}.tmp.XXXXXX")

  case "$mapping_strategy" in
    provider-managed)
      jq --arg token "$token" \
         --arg base_url "$base_url" \
         '.env.ANTHROPIC_AUTH_TOKEN = $token |
          .env.ANTHROPIC_BASE_URL = $base_url' \
         "$SETTINGS" > "$tmp_settings"
      ;;
    fixed)
      jq --arg token "$token" \
         --arg base_url "$base_url" \
         --arg opus "$(get_provider_model_value "$provider" "opus")" \
         --arg sonnet "$(get_provider_model_value "$provider" "sonnet")" \
         --arg haiku "$(get_provider_model_value "$provider" "haiku")" \
         '.env.ANTHROPIC_AUTH_TOKEN = $token |
          .env.ANTHROPIC_BASE_URL = $base_url |
          .env.ANTHROPIC_DEFAULT_OPUS_MODEL = $opus |
          .env.ANTHROPIC_DEFAULT_SONNET_MODEL = $sonnet |
          .env.ANTHROPIC_DEFAULT_HAIKU_MODEL = $haiku' \
         "$SETTINGS" > "$tmp_settings"
      ;;
    single-model)
      local selected_model="$override_model"
      if [ -z "$selected_model" ]; then
        selected_model="${OPENROUTER_DEFAULT_MODEL:-$(get_provider_default_model "$provider")}"
      fi
      if [ -z "$selected_model" ]; then
        echo -e "${RED}❌ No model specified${NC}"
        echo "Usage: claude-switch openrouter:<model>"
        echo ""
        echo "Popular Claude models on OpenRouter:"
        echo "  anthropic/claude-opus-4.6       (Claude Opus 4.6 - latest)"
        echo "  anthropic/claude-sonnet-4     (Claude Sonnet 4.5)"
        echo "  anthropic/claude-haiku-4      (Claude Haiku 4.5)"
        echo ""
        echo "Example: claude-switch openrouter:anthropic/claude-opus-4.6"
        echo ""
        echo "Or set OPENROUTER_DEFAULT_MODEL in ~/.claude/api-keys.env"
        rm -f "$tmp_settings"
        return 1
      fi
      jq --arg token "$token" \
         --arg base_url "$base_url" \
         --arg model "$selected_model" \
         '.env.ANTHROPIC_AUTH_TOKEN = $token |
          .env.ANTHROPIC_BASE_URL = $base_url |
          .env.ANTHROPIC_API_KEY = "" |
          .env.ANTHROPIC_DEFAULT_OPUS_MODEL = $model |
          .env.ANTHROPIC_DEFAULT_SONNET_MODEL = $model |
          .env.ANTHROPIC_DEFAULT_HAIKU_MODEL = $model' \
         "$SETTINGS" > "$tmp_settings"
      ;;
    *)
      rm -f "$tmp_settings"
      return 1
      ;;
  esac

  mv "$tmp_settings" "$SETTINGS"
  return 0
}

apply_config() {
  local provider="$1"
  local override_model="$2"

  if [ -n "$override_model" ]; then
    validate_model_name "$override_model" || return 1
  fi

  case "$provider" in
    z.ai|glm) provider="zai" ;;
  esac

  cp "$SETTINGS" "$BACKUP_DIR/settings.json.backup-$(date +%Y%m%d-%H%M%S)"

  if provider_exists "$provider" && [ "$provider" != "claude" ]; then
    apply_catalog_provider "$provider" "$override_model" || return 1
    chmod 600 "$SETTINGS"
    return 0
  fi

  case "$provider" in
    claude)
      clear_all_models
      clear_provider_connection
      ;;

    ollama)
      check_ollama || return 1
      clear_all_models
      local opus_model=""
      local sonnet_model=""
      local haiku_model=""
      local installed_models=$(ollama list 2>/dev/null | tail -n +2 | awk '{print $1}')

      if [ -n "$override_model" ]; then
        opus_model="${override_model%:latest}"
        sonnet_model="$opus_model"
        haiku_model="$opus_model"
      else
        opus_model="qwen3-coder:32b"
        sonnet_model="qwen3-coder:14b"
        haiku_model="qwen3-coder:7b"

        if ! echo "$installed_models" | grep -q "^${opus_model}"; then
          opus_model="qwen3-coder:14b"
        fi
        if ! echo "$installed_models" | grep -q "^${opus_model}"; then
          opus_model="qwen3-coder:7b"
        fi
        if ! echo "$installed_models" | grep -q "^${opus_model}"; then
          opus_model=$(echo "$installed_models" | head -1)
        fi

        if ! echo "$installed_models" | grep -q "^${sonnet_model}"; then
          sonnet_model="$opus_model"
        fi
        if ! echo "$installed_models" | grep -q "^${haiku_model}"; then
          haiku_model="$sonnet_model"
        fi

        if [ -z "$opus_model" ]; then
          echo -e "${RED}❌ No Ollama models installed${NC}"
          echo "Download models:"
          echo "  ollama pull qwen3-coder:7b   # Haiku tier (default, fast)"
          echo "  ollama pull qwen3-coder:14b  # Sonnet tier"
          echo "  ollama pull qwen3-coder:32b  # Opus tier (if you have RAM)"
          return 1
        fi
      fi

      opus_model="${opus_model%:latest}"
      sonnet_model="${sonnet_model%:latest}"
      haiku_model="${haiku_model%:latest}"

      echo -e "${YELLOW}Model mapping:${NC}"
      echo -e "  Opus   → $opus_model"
      echo -e "  Sonnet → $sonnet_model"
      echo -e "  Haiku  → $haiku_model ${CYAN}(default for local)${NC}"

      local tmp_settings
      tmp_settings=$(mktemp "${SETTINGS}.tmp.XXXXXX")
      jq --arg opus "$opus_model" \
         --arg sonnet "$sonnet_model" \
         --arg haiku "$haiku_model" \
         '.env.ANTHROPIC_AUTH_TOKEN = "ollama" |
          .env.ANTHROPIC_BASE_URL = "http://localhost:11434" |
          .env.ANTHROPIC_MODEL = $haiku |
          .env.ANTHROPIC_DEFAULT_OPUS_MODEL = $opus |
          .env.ANTHROPIC_DEFAULT_SONNET_MODEL = $sonnet |
          .env.ANTHROPIC_DEFAULT_HAIKU_MODEL = $haiku' \
         "$SETTINGS" > "$tmp_settings"
      mv "$tmp_settings" "$SETTINGS"
      ;;

    lmstudio)
      check_lmstudio || return 1
      clear_all_models
      local tmp_settings
      tmp_settings=$(mktemp "${SETTINGS}.tmp.XXXXXX")
      jq '.env.ANTHROPIC_AUTH_TOKEN = "lmstudio" |
          .env.ANTHROPIC_BASE_URL = "http://localhost:1234/v1"' \
         "$SETTINGS" > "$tmp_settings"
      mv "$tmp_settings" "$SETTINGS"
      ;;

    *)
      echo -e "${RED}❌ Unknown provider:${NC} $provider"
      echo "Run: claude-switch help"
      return 1
      ;;
  esac

  chmod 600 "$SETTINGS"
  return 0
}

run_switch_flow() {
  local raw_provider="$1"
  local show_hint="${2:-true}"
  local auto_yes="${3:-$AUTO_YES}"
  local provider
  local override_model
  local current
  local current_name
  local target_name

  IFS=':' read -r provider override_model <<< "$raw_provider"

  if [ -n "$override_model" ]; then
    validate_model_name "$override_model" || return 1
  fi

  case "$provider" in
    z.ai|glm) provider="zai" ;;
  esac

  current=$(get_current_config_for_scope)
  current_name=$(get_friendly_name "$current")

  echo -e "${YELLOW}Current status:${NC} $current_name"

  if [ "$current" = "$provider" ] && [ -z "$override_model" ]; then
    if ! provider_config_needs_refresh "$provider"; then
      echo -e "${GREEN}✓${NC} Already configured for $(get_friendly_name "$provider")"
      return 0
    fi
    echo -e "${YELLOW}Refreshing:${NC} $(get_friendly_name "$provider") to normalize legacy settings"
  fi

  target_name=$(get_friendly_name "$provider")
  if [ -n "$override_model" ]; then
    target_name="$target_name ($override_model)"
  fi

  echo -e "${YELLOW}Switch to:${NC} $target_name"
  if [ "$auto_yes" = "true" ]; then
    echo "Confirmation: auto-approved via --yes"
  else
    read -p "Confirm? [y/N] " -n 1 -r
    echo

    if [[ ! $REPLY =~ ^[SsYy]$ ]]; then
      echo "Operation cancelled"
      return 1
    fi
  fi

  ensure_settings_file

  if apply_config "$provider" "$override_model"; then
    echo -e "${GREEN}✅ Configured for $target_name${NC}"
    show_applied_model_mapping "$provider"

    if pgrep -f "node.*claude-code" > /dev/null || pgrep -f "@anthropic-ai/claude-code" > /dev/null; then
      echo -e "\n${YELLOW}⚠️  Claude Code is running${NC}"
      if [ "$auto_yes" = "true" ]; then
        echo "Skip killing active sessions in --yes mode"
      else
        read -p "Kill active sessions? [y/N] " -n 1 -r
        echo

        if [[ $REPLY =~ ^[SsYy]$ ]]; then
          pkill -f "node.*claude-code" 2>/dev/null
          pkill -f "@anthropic-ai/claude-code" 2>/dev/null
          echo -e "${GREEN}✓${NC} Sessions terminated"
        fi
      fi
    fi

    if [ "$show_hint" = "true" ]; then
      show_launch_hint
    fi
    return 0
  fi

  echo -e "${RED}❌ Configuration failed${NC}"
  return 1
}

handle_exec_command() {
  local provider_spec=""
  local auto_yes="$AUTO_YES"

  while [ $# -gt 0 ]; do
    case "$1" in
      -y|--yes)
        auto_yes="true"
        shift
        ;;
      --)
        shift
        break
        ;;
      -*)
        break
        ;;
      *)
        if [ -z "$provider_spec" ]; then
          provider_spec="$1"
          shift
        else
          break
        fi
        ;;
    esac
  done

  if [ -n "$provider_spec" ]; then
    run_switch_flow "$provider_spec" false "$auto_yes" || return 1
  fi

  show_launch_summary

  launch_claude_for_account "$CURRENT_ACCOUNT" "$@"
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MAIN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if [ "${1:-}" = "-y" ] || [ "${1:-}" = "--yes" ]; then
  AUTO_YES="true"
  shift
fi

case "${1:-}" in
  ""|help|-h|--help) show_help; exit 0 ;;
  wizard|config) run_wizard; exit 0 ;;
  update) do_update; exit 0 ;;
  update-config) do_update_config; exit 0 ;;
  check-updates) check_updates; exit 0 ;;
  --version) echo "v${VERSION}"; exit 0 ;;
esac

if [ "${1:-}" = "doctor" ] && ! command -v jq > /dev/null 2>&1; then
  shift
  run_doctor_missing_jq "$@"
  exit $?
fi

ensure_switcher_state

case "$1" in
  keys|docs) show_key_docs; exit 0 ;;
  list|ls) list_providers; exit 0 ;;
  status|current) show_status; exit 0 ;;
  where) show_where; exit 0 ;;
  doctor) shift; run_doctor "$@"; exit $? ;;
  models) show_model_mapping "$2"; exit 0 ;;
  account) shift; handle_account_command "$@"; exit $? ;;
  profile) shift; handle_profile_command "$@"; exit $? ;;
  provider) shift; handle_provider_command "$@"; exit $? ;;
  global) shift; handle_scoped_switch_command "global" "$@"; exit $? ;;
  project) shift; handle_scoped_switch_command "project" "$@"; exit $? ;;
  reset)
    shift
    case "${1:-}" in
      project) reset_project_scope; exit $? ;;
      *)
        echo -e "${RED}❌ Unknown reset target:${NC} ${1:-}"
        echo "Usage: claude-switch reset project"
        exit 1
        ;;
    esac
    ;;
  exec) shift; handle_exec_command "$@"; exit $? ;;
esac

if [ "${2:-}" = "-y" ] || [ "${2:-}" = "--yes" ]; then
  AUTO_YES="true"
fi

use_scope_target "global" || exit 1
run_switch_flow "$1" true "$AUTO_YES"
exit $?
