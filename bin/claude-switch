get_ollama_models() {
  local installed=$(ollama list 2>/dev/null | tail -n +2 | awk '{print $1}')
  local opus="qwen3-coder:32b" sonnet="qwen3-coder:14b" haiku="qwen3-coder:7b"

  echo "$installed" | grep -q "^${opus}" || opus="$sonnet"
  echo "$installed" | grep -q "^${opus}" || opus="$haiku"
  echo "$installed" | grep -q "^${sonnet}" || sonnet="$opus"
  echo "$installed" | grep -q "^${haiku}" || haiku="$sonnet"

  if [ -z "$opus" ]; then
    opus=$(echo "$installed" | head -1)
    sonnet="$opus"
    haiku="$opus"
  fi

  echo "opus:$opus sonnet:$sonnet haiku:$haiku"
}

get_lmstudio_models() {
  echo "opus: sonnet: haiku:"
}

download_remote_file() {
  local url="$1"
  local dest="$2"

  if [[ "$url" == file://* ]]; then
    cp "${url#file://}" "$dest"
    return 0
  fi

  if command -v curl > /dev/null 2>&1; then
    curl -fsSL "$url" -o "$dest"
  elif command -v wget > /dev/null 2>&1; then
    wget -q "$url" -O "$dest"
  else
    echo -e "${RED}❌ Neither curl nor wget is available${NC}"
    return 1
  fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# UPDATE FUNCTIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

check_updates() {
  echo -e "${CYAN}Checking for updates...${NC}"
  local latest_version
  latest_version=$(curl -s "https://api.github.com/repos/renatoroquejani/claude-code-switcher/releases/latest" | jq -r '.tag_name // ""' 2>/dev/null)

  if [ -z "$latest_version" ]; then
    echo -e "${YELLOW}⚠️  Could not check for updates${NC}"
    echo "Visit $REPO_URL/releases to check manually"
    return 1
  fi

  latest_version="${latest_version#v}"

  if [ "$latest_version" = "$VERSION" ]; then
    echo -e "${GREEN}✓${NC} You're on the latest version: ${BOLD}v${VERSION}${NC}"
    return 0
  fi

  echo -e "${YELLOW}New version available:${NC} v${latest_version}"
  echo -e "${YELLOW}Current version:${NC}     v${VERSION}"
  echo ""
  echo "Update with: ${GREEN}claude-switch update${NC}"
  echo "Or visit: $REPO_URL/releases"
  return 0
}

do_update() {
  local temp_dir
  temp_dir=$(mktemp -d)

  echo -e "${CYAN}Downloading latest version...${NC}"

  local download_url="$RAW_BASE_URL/bin/claude-switch"
  if ! download_remote_file "$download_url" "$temp_dir/claude-switch"; then
    echo -e "${RED}❌ Failed to download update${NC}"
    rm -rf "$temp_dir"
    return 1
  fi

  chmod +x "$temp_dir/claude-switch"

  local script_path
  script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  cp "$script_path" "${script_path}.backup"
  echo -e "${GREEN}✓${NC} Backup created: ${script_path}.backup"

  mv "$temp_dir/claude-switch" "$script_path"
  rm -rf "$temp_dir"

  echo -e "${GREEN}✓${NC} Updated successfully!"
  echo ""
  echo "Run ${GREEN}claude-switch update-config${NC} to refresh provider presets if needed."
  echo ""
  echo "New version:"
  bash "$script_path" --version 2>/dev/null || echo "v$(grep '^VERSION=' "$script_path" | cut -d'"' -f2)"
}

do_update_config() {
  local temp_dir
  local temp_file
  local download_url
  local bundled_file
  local using_local_fallback="false"

  temp_dir=$(mktemp -d)
  temp_file="$temp_dir/providers.json"
  download_url="${CLAUDE_SWITCHER_CONFIG_URL:-$RAW_BASE_URL/config/providers.json}"

  echo -e "${CYAN}Downloading latest provider config...${NC}"

  if ! download_remote_file "$download_url" "$temp_file"; then
    if [ -z "${CLAUDE_SWITCHER_CONFIG_URL:-}" ] && bundled_file=$(get_bundled_providers_file 2>/dev/null); then
      cp "$bundled_file" "$temp_file"
      using_local_fallback="true"
      echo -e "${YELLOW}⚠️  Remote provider config unavailable, using local checkout copy${NC}"
    else
      echo -e "${RED}❌ Failed to download provider config${NC}"
      rm -rf "$temp_dir"
      return 1
    fi
  fi

  if ! jq empty "$temp_file" > /dev/null 2>&1; then
    echo -e "${RED}❌ Downloaded provider config is invalid JSON${NC}"
    rm -rf "$temp_dir"
    return 1
  fi

  mkdir -p "$(dirname "$PROVIDERS_FILE")"
  if [ -f "$PROVIDERS_FILE" ]; then
    cp "$PROVIDERS_FILE" "${PROVIDERS_FILE}.backup"
    chmod 600 "${PROVIDERS_FILE}.backup" 2>/dev/null || true
    echo -e "${GREEN}✓${NC} Backup created: ${PROVIDERS_FILE}.backup"
  fi

  mv "$temp_file" "$PROVIDERS_FILE"
  chmod 600 "$PROVIDERS_FILE" 2>/dev/null || true
  rm -rf "$temp_dir"

  echo -e "${GREEN}✓${NC} Provider config updated: $PROVIDERS_FILE"
  if [ "$using_local_fallback" = "true" ]; then
    echo "Source: $bundled_file"
  fi
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DOCUMENTATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

run_wizard() {
  local wizard_script="$(dirname "${BASH_SOURCE[0]}")/../scripts/config-wizard.sh"

  if [ ! -f "$wizard_script" ]; then
    echo -e "${RED}❌ Configuration wizard not found${NC}"
    echo "Expected location: $wizard_script"
    return 1
  fi

  if [ ! -x "$wizard_script" ]; then
    chmod +x "$wizard_script"
  fi

  exec bash "$wizard_script"
}

